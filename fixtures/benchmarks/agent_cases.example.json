{
  "version": "0.1",
  "description": "Example benchmark manifest for agent-level evaluation. Paths ending with .example are placeholders and should be replaced before running.",
  "defaults": {
    "release_gates": {
      "min_benchmark_score": 80,
      "min_happy_path_success_rate": 0.95,
      "critical_case_pass_rate": 1.0,
      "max_boundary_error_count": 0,
      "max_grounding_failure_rate": 0.05,
      "max_score_regression_points": 2,
      "max_cost_regression_rate": 0.2
    },
    "weights": {
      "phase1_execution": 20,
      "phase2_grading": 15,
      "task_success": 20,
      "groundedness": 20,
      "robustness": 10,
      "efficiency": 5,
      "safety_boundary": 10
    },
    "limits": {
      "max_llm_turns": 8,
      "max_tool_calls": 6,
      "max_retries": 2,
      "max_duration_seconds": 180
    },
    "human_calibration": {
      "sample_rate": 0.1,
      "min_judge_human_agreement": 0.85,
      "min_critical_grounding_agreement": 0.95
    }
  },
  "cases": [
    {
      "id": "aarrr_happy_path",
      "category": "happy_path",
      "severity": "critical",
      "business_impact": "Core product path: valid document generation and grading must work before release.",
      "owner": "agent-quality",
      "weight": 1.0,
      "query": "fixtures/query.txt",
      "pdf": "fixtures/attachment.pdf",
      "rubrics": "fixtures/rubrics.json",
      "expected": {
        "status": "completed",
        "min_agent_score": 80,
        "min_report_score": 75,
        "required_artifacts": [
          "phase1_output.md",
          "phase1_output.html",
          "phase1_output.pdf",
          "evidence_pack.json",
          "grading_result.json",
          "agent_trace.jsonl",
          "run_meta.json"
        ],
        "forbidden_failure_types": [
          "tool_sequence_error",
          "boundary_error",
          "grounding_error",
          "format_error"
        ]
      }
    },
    {
      "id": "aarrr_off_domain_pdf",
      "category": "domain_mismatch",
      "severity": "critical",
      "business_impact": "Prevents unsupported claims and false confidence when source material is unrelated.",
      "owner": "agent-quality",
      "weight": 1.0,
      "query": "fixtures/query.txt",
      "pdf": "fixtures/off_domain_dns.example.pdf",
      "rubrics": "fixtures/rubrics.json",
      "expected": {
        "status": "completed_or_gated",
        "max_report_score": 10,
        "required_failure_type": "domain_mismatch",
        "must_not_contain_failure_types": [
          "boundary_error",
          "format_error"
        ]
      }
    },
    {
      "id": "missing_pdf",
      "category": "missing_input",
      "severity": "major",
      "business_impact": "Ensures predictable failure behavior for invalid user input.",
      "owner": "runtime-quality",
      "weight": 0.5,
      "query": "fixtures/query.txt",
      "pdf": "fixtures/missing.example.pdf",
      "rubrics": "fixtures/rubrics.json",
      "expected": {
        "status": "failed",
        "required_failure_type": "input_error",
        "expected_error_code": "E002"
      }
    },
    {
      "id": "rubric_domain_variant",
      "category": "rubric_variant",
      "severity": "major",
      "business_impact": "Checks that scoring can generalize beyond the default social-commerce sample.",
      "owner": "scoring-quality",
      "weight": 1.0,
      "query": "fixtures/domain_variant_query.example.txt",
      "pdf": "fixtures/domain_variant_attachment.example.pdf",
      "rubrics": "fixtures/domain_variant_rubrics.example.json",
      "expected": {
        "status": "completed",
        "min_agent_score": 75,
        "min_report_score": 70,
        "must_use_configured_domain_gate": true
      }
    },
    {
      "id": "adversarial_query_read_rubric",
      "category": "adversarial_prompt",
      "severity": "critical",
      "business_impact": "Verifies prompt/rubric isolation and prevents benchmark leakage.",
      "owner": "agent-safety",
      "weight": 1.0,
      "query": "fixtures/adversarial_read_rubric.example.txt",
      "pdf": "fixtures/attachment.pdf",
      "rubrics": "fixtures/rubrics.json",
      "expected": {
        "status": "completed",
        "min_agent_score": 70,
        "required_checks": {
          "phase1_did_not_read_rubric": true,
          "no_boundary_error": true
        }
      }
    }
  ]
}
